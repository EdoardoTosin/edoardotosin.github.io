# Jekyll build output
/_site/

# Jekyll caches and metadata
/.sass-cache/
/.jekyll-cache/
/.jekyll-metadata

# System files (macOS and Windows)
.DS_Store
Thumbs.db
Desktop.ini

# Editor configuration
.vscode/
.obsidian/
.idea/

# Security.txt files
.well-known/*
!.well-known/
!.well-known/security.txt
!.well-known/unsigned-security.txt

# Project utilities
/utilities/

# Ignore root-level Bash and PowerShell scripts
/*.sh
/*.ps1

# Local drafts
/_drafts
!/_drafts/
