---
layout: null
permalink: /search.json
---
{%- comment %}Search index for BM25 engine in search.js. Fields: title, description, excerpt, topic, tags, keywords, content, headings_text.{%- endcomment %}
[
{%- for post in site.posts -%}
{%- assign _words = post.content | number_of_words -%}
{%- assign _mins  = _words | divided_by: 200 | plus: 1 -%}
{%- if post.video == true -%}
  {%- assign _type = "video" -%}
{%- elsif post.gallery == true -%}
  {%- assign _type = "gallery" -%}
{%- else -%}
  {%- assign _type = "post" -%}
{%- endif -%}

{%- comment %} Strip code blocks before text extraction to reduce index noise {%- endcomment -%}
{%- assign _raw = post.content -%}
{%- assign _stripped = _raw -%}
{%- assign _pre_parts = _raw | split: '<pre' -%}
{%- assign _stripped = _pre_parts[0] -%}
{%- for _part in _pre_parts -%}
  {%- unless forloop.first -%}
    {%- assign _after_pre = _part | split: '</pre>' -%}
    {%- if _after_pre.size > 1 -%}
      {%- assign _stripped = _stripped | append: _after_pre[1] -%}
    {%- endif -%}
  {%- endunless -%}
{%- endfor -%}

{%- comment %} Main prose content with sentence boundaries {%- endcomment -%}
{%- assign _content = _stripped
  | replace: '</h1', '. </h1'
  | replace: '</h2', '. </h2'
  | replace: '</h3', '. </h3'
  | replace: '</h4', '. </h4'
  | replace: '</p',  '. </p'
  | replace: '</li', ', </li'
  | replace: '</tr', '. </tr'
  | replace: '<hr',  '. <hr'
  | strip_html
  | normalize_whitespace
  | replace: '. . .', '.'
  | replace: '. .',   '.'
  | replace: ', ,',   ','
  | truncate: 12000
-%}

{%- comment %} Short excerpt for snippet fallback {%- endcomment -%}
{%- assign _excerpt = _content | truncate: 280 -%}

{%- comment %} Extract heading text (h2/h3/h4) as a high-signal search field {%- endcomment -%}
{%- assign _headings = '' -%}
{%- assign _h_splits = post.content | split: '<h2' -%}
{%- for _hpart in _h_splits -%}{%- unless forloop.first -%}
  {%- assign _htext = _hpart | split: '</h2>' | first | strip_html | normalize_whitespace -%}
  {%- assign _headings = _headings | append: ' ' | append: _htext -%}
{%- endunless -%}{%- endfor -%}
{%- assign _h_splits = post.content | split: '<h3' -%}
{%- for _hpart in _h_splits -%}{%- unless forloop.first -%}
  {%- assign _htext = _hpart | split: '</h3>' | first | strip_html | normalize_whitespace -%}
  {%- assign _headings = _headings | append: ' ' | append: _htext -%}
{%- endunless -%}{%- endfor -%}
{%- assign _h_splits = post.content | split: '<h4' -%}
{%- for _hpart in _h_splits -%}{%- unless forloop.first -%}
  {%- assign _htext = _hpart | split: '</h4>' | first | strip_html | normalize_whitespace -%}
  {%- assign _headings = _headings | append: ' ' | append: _htext -%}
{%- endunless -%}{%- endfor -%}
{
  "id": {{ post.id | jsonify }},
  "title": {{ post.title | jsonify }},
  "slug": {{ post.url | jsonify }},
  "url": {{ post.url | relative_url | jsonify }},
  {% if post.short_url %}"short_url": {{ post.short_url | relative_url | jsonify }},{% endif %}
  "description": {{ post.description | default: "" | jsonify }},
  "excerpt": {{ _excerpt | jsonify }},
  "headings": {{ _headings | strip | jsonify }},
  "content": {{ _content | jsonify }},
  "topic": {{ post.topic | default: "" | jsonify }},
  "tags": {{ post.tags | default: "" | jsonify }},
  "keywords": {{ post.keywords | default: "" | jsonify }},
  "categories": {{ post.categories | default: "" | jsonify }},
  "author": {{ site.author.name | jsonify }},
  "date": {{ post.date | date: "%d %b, %Y" | jsonify }},
  "date_iso": {{ post.date | date_to_xmlschema | jsonify }},
  "modified_iso": {{ post.last_modified_at | default: post.date | date_to_xmlschema | jsonify }},
  "image": {{ post.image | default: "/images/social-preview.jpg" | relative_url | jsonify }},
  "type": {{ _type | jsonify }},
  "featured": {{ post.featured | default: false | jsonify }},
  "reading_time": {{ _mins }},
  "word_count": {{ _words }}
}{% unless forloop.last %},{% endunless %}
{%- endfor -%}
]
