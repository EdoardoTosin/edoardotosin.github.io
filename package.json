{
  "name": "edoardotosin.github.io",
  "version": "1.0.0",
  "description": "Custom Jekyll theme for a personal blog and portfolio. Dark-mode-first, responsive, accessible (WCAG AA), no CSS framework.",
  "main": "sw.js",
  "directories": {
    "doc": "docs"
  },
  "devDependencies": {
    "@shopify/prettier-plugin-liquid": "^1.10.3",
    "jest": "^30.4.2"
  },
  "scripts": {
    "test": "jest",
    "serve:dev": "bundle exec jekyll serve --config _config.yml,_config.dev.yml --livereload",
    "ci": "npm run format:check && npm run test",
    "audit": "node scripts/audit.js",
    "audit:deps": "npm audit",
    "format": "prettier --write \"**/*.{html,js,scss,md,yml}\"",
    "format:check": "prettier --check \"**/*.{html,js,scss,md,yml}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EdoardoTosin/edoardotosin.github.io.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/EdoardoTosin/edoardotosin.github.io/issues"
  },
  "homepage": "https://github.com/EdoardoTosin/edoardotosin.github.io#readme",
  "jest": {
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/_site/"
    ]
  },
  "dependencies": {
    "axe-core": "^4.12.1",
    "jsdom": "^29.1.1"
  }
}
